{
  "expo": {
    "name": "FluxService",
    "slug": "fluxservice",
    "scheme": "fluxservice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B7EF6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fluxservice.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FluxService needs camera access to take photos of plumbing issues.",
        "NSPhotoLibraryUsageDescription": "FluxService needs photo library access to attach images to enquiries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B7EF6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.fluxservice.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "FluxService needs photo library access to attach images to enquiries.",
          "cameraPermission": "FluxService needs camera access to take photos of plumbing issues."
        }
      ],
      "expo-web-browser"
    ]
  }
}
